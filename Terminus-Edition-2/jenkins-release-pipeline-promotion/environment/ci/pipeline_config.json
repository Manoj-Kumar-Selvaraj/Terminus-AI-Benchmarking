{
  "credentialBindings": {
    "staging": "cred-staging",
    "production": "cred-staging"
  },
  "workspace": {
    "parallelIsolation": false,
    "cacheKeyIncludesAxis": false
  },
  "promotionGate": {
    "scanSource": "branch_tip",
    "requiredStatus": "PASS"
  },
  "rollback": {
    "strategy": "rebuild_head",
    "preservePriorDigest": false
  },
  "compat": {
    "manifestSchema": "v1",
    "stageNames": [
      "Build",
      "Integration",
      "Quality Gate",
      "Promote",
      "Rollback"
    ]
  }
}