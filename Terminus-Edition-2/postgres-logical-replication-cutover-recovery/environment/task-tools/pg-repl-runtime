#!/usr/bin/env python3
from __future__ import annotations
import argparse, json, sys
from runtime_lib import *

def emit(value): print(json.dumps(value,indent=2,sort_keys=True))
def main():
    p=argparse.ArgumentParser(prog="pg-repl-runtime")
    sub=p.add_subparsers(dest="cmd",required=True)
    sub.add_parser("reset")
    a=sub.add_parser("apply-source"); a.add_argument("--file",required=True)
    a=sub.add_parser("apply-target"); a.add_argument("--file",required=True)
    a=sub.add_parser("replicate"); a.add_argument("--until-lsn")
    a=sub.add_parser("inspect"); a.add_argument("what",choices=["publication","subscription","slot","source","target","cutover","journal"])
    sub.add_parser("repair-publication")
    sub.add_parser("validate-schema")
    sub.add_parser("validate-sequences")
    sub.add_parser("sync-sequences")
    a=sub.add_parser("readiness"); a.add_argument("--fence-lsn")
    a=sub.add_parser("cutover"); a.add_argument("--operation-id",required=True)
    a=sub.add_parser("rollback"); a.add_argument("--operation-id",required=True); a.add_argument("--cutover-operation-id")
    sub.add_parser("restart-controller")
    a=sub.add_parser("inject-failure"); a.add_argument("--point",required=True)
    sub.add_parser("clear-failure")
    sub.add_parser("verify-integrity")
    ns=p.parse_args()
    if ns.cmd=="reset": out=reset()
    elif ns.cmd=="apply-source": out=apply_source(ns.file)
    elif ns.cmd=="apply-target": out=apply_target(ns.file)
    elif ns.cmd=="replicate": out=controller_call("replicate",ns.until_lsn)
    elif ns.cmd=="inspect": out=inspect(ns.what)
    elif ns.cmd=="repair-publication": out=controller_call("repair_publication")
    elif ns.cmd=="validate-schema": out=controller_call("validate_schema")
    elif ns.cmd=="validate-sequences": out=controller_call("validate_sequences")
    elif ns.cmd=="sync-sequences": out=controller_call("sync_sequences")
    elif ns.cmd=="readiness": out=controller_call("readiness",ns.fence_lsn)
    elif ns.cmd=="cutover": out=controller_call("cutover",ns.operation_id)
    elif ns.cmd=="rollback": out=controller_call("rollback",ns.operation_id,ns.cutover_operation_id)
    elif ns.cmd=="restart-controller": out=restart_controller()
    elif ns.cmd=="inject-failure": out=inject(ns.point)
    elif ns.cmd=="clear-failure": out=clear_failure()
    elif ns.cmd=="verify-integrity": out=verify_integrity()
    emit(out)
if __name__=="__main__":
    try: main()
    except Exception as exc:
        print(json.dumps({"status":"error","error":str(exc)},sort_keys=True),file=sys.stderr)
        raise SystemExit(2)
