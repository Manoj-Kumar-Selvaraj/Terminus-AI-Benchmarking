# ATM Risk Release Rule Deck
# PL/I-style declarations consumed by the COBOL reconciler.
DCL ELIGIBLE_HOLD_STATUS CHAR(8) INIT('HELD');
DCL OPEN_WINDOW_STATUS CHAR(4) INIT('OPEN');
DCL REASON_APPROVE CHAR(8) INIT('CLEAR');
DCL REASON_REVIEW CHAR(8) INIT('REVIEW');
DCL REASON_EXPIRE CHAR(8) INIT('EXPIRE');
DCL ALIAS_ATM CHAR(16) INIT('ATM=>CASH');
DCL ALIAS_POS CHAR(16) INIT('POS=>MERCHANT');
DCL ALIAS_WEB CHAR(16) INIT('WEB=>ONLINE');