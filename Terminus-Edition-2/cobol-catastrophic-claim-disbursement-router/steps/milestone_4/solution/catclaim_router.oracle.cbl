IDENTIFICATION DIVISION.
PROGRAM-ID. catclaim-router.
ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT CLAIMS-FILE ASSIGN TO "/app/data/claims.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT POLICIES-FILE ASSIGN TO "/app/data/policies.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT DIAG-FILE ASSIGN TO "/app/config/diagnosis_policy.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT FAC-FILE ASSIGN TO "/app/config/facility_trust.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT DECK-FILE ASSIGN TO "/app/config/payment_policy.pli"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT REJ-PREC-FILE ASSIGN TO "/app/config/reject_precedence.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT REV-PREC-FILE ASSIGN TO "/app/config/review_reason_precedence.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT BANK-FILE ASSIGN TO "/app/data/bank_verification_responses.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT PRIOR-LED-FILE ASSIGN TO "/app/data/prior_disbursement_ledger.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT OUT-LED-FILE ASSIGN TO "/app/out/payment_ledger.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT DECISIONS-FILE ASSIGN TO "/app/out/payment_decision_report.psv"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT REJECTS-FILE ASSIGN TO "/app/out/reject_ledger.psv"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT REVIEWS-FILE ASSIGN TO "/app/out/manual_review_queue.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT CHECKS-FILE ASSIGN TO "/app/out/check_queue.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT EFT-FILE ASSIGN TO "/app/out/eft_queue.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT VERIFY-FILE ASSIGN TO "/app/out/bank_verify_messages.psv"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
    SELECT CONTROL-FILE ASSIGN TO "/app/out/control_totals.psv"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT CHECKPOINT-FILE ASSIGN TO "/app/out/restart_checkpoint.txt"
        ORGANIZATION IS LINE SEQUENTIAL FILE STATUS IS WS-FS.
DATA DIVISION.
FILE SECTION.
