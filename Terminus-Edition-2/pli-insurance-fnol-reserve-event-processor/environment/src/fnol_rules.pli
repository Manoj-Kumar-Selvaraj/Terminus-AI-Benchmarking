DCL ELIGIBLE_STATUS CHAR(12) INIT('OPEN');
DCL OPEN_WINDOW_STATUS CHAR(8) INIT('OPEN');
DCL REASON_A CHAR(12) INIT('RAISE');
DCL REASON_B CHAR(12) INIT('LOWER');
DCL REASON_C CHAR(12) INIT('CLOSE');
DCL NEGATIVE_REASON_CODES CHAR(40) INIT('LOWER,CLOSE');
DCL ALIAS_1 CHAR(20) INIT('A=>AUTO');
DCL ALIAS_2 CHAR(20) INIT('H=>HOME');
DCL ALIAS_3 CHAR(20) INIT('L=>LIAB');
